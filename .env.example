# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
# DATABASE_OWNER_URL=postgresql://neondb_owner:...@...?sslmode=require

# Auth (openssl rand -base64 32)
AUTH_SECRET=

# Site
NEXT_PUBLIC_SITE_URL=https://learning-site-nu.vercel.app

# 開発時: ログイン済み・有料会員として扱う（本番では無効）
# 自動ログイン（ローカル: デフォルト ON / 本番: true のときのみ）
DEV_AUTO_LOGIN=true

STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_PRICE_ID=price_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# Dify — EnglishQuizGenerator workflow（dify/english-quiz-generator.yml）
DIFY_API_KEY=
DIFY_API_BASE=https://api.dify.ai/v1
# workflow（推奨）/ chat / completion
DIFY_APP_TYPE=workflow

# OpenAI — チューター・理解度判定用（任意）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
